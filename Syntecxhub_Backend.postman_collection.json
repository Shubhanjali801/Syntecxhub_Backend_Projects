              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Getting Started with Node.js\",\n  \"body\": \"Node.js is a JavaScript runtime built on Chrome's V8 engine. It allows you to run JavaScript on the server side. In this post we will explore the basics of Node.js and build a simple REST API.\",\n  \"author\": \"Shubhanjali\",\n  \"tags\": [\"node\", \"javascript\", \"backend\"]\n}"
                },
                "url": { "raw": "{{BASE_URL}}/posts", "host": ["{{BASE_URL}}"], "path": ["posts"] }
              }
            },
            {
              "name": "Create Post - MongoDB",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"MongoDB Aggregation Pipeline Explained\",\n  \"body\": \"The MongoDB aggregation pipeline is a powerful framework for data transformation. Using stages like $match, $group, and $project, you can perform complex queries efficiently.\",\n  \"author\": \"Riya\",\n  \"tags\": [\"mongodb\", \"database\", \"backend\"]\n}"
                },
                "url": { "raw": "{{BASE_URL}}/posts", "host": ["{{BASE_URL}}"], "path": ["posts"] }
              }
            },
            {
              "name": "Create Post - React",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"React Hooks - useState and useEffect\",\n  \"body\": \"React Hooks let you use state and lifecycle features in functional components. useState manages local state while useEffect handles side effects like API calls.\",\n  \"author\": \"Shubhanjali\",\n  \"tags\": [\"react\", \"javascript\", \"frontend\"]\n}"
                },
                "url": { "raw": "{{BASE_URL}}/posts", "host": ["{{BASE_URL}}"], "path": ["posts"] }
              }
            },
            {
              "name": "Get All Posts",
              "request": {
                "method": "GET",
                "url": { "raw": "{{BASE_URL}}/posts", "host": ["{{BASE_URL}}"], "path": ["posts"] }
              }
            },
            {
              "name": "Filter by Tag",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{BASE_URL}}/posts?tag=node",
                  "host": ["{{BASE_URL}}"],
                  "path": ["posts"],
                  "query": [{ "key": "tag", "value": "node" }]
                }
              }
            },
            {
              "name": "Filter by Author",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{BASE_URL}}/posts?author=Shubhanjali",
                  "host": ["{{BASE_URL}}"],
                  "path": ["posts"],
                  "query": [{ "key": "author", "value": "Shubhanjali" }]
                }
              }
            },
            {
              "name": "Sort - Oldest First",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{BASE_URL}}/posts?sort=oldest",
                  "host": ["{{BASE_URL}}"],
                  "path": ["posts"],
                  "query": [{ "key": "sort", "value": "oldest" }]
                }
              }
            },
            {
              "name": "Pagination - Page 1 Limit 2",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{BASE_URL}}/posts?page=1&limit=2",
